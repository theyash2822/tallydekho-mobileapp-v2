\n\u2022 We use minimal analytics to improve app performance\n\u2022 No advertising cookies or third-party trackers are used\n\n6. YOUR RIGHTS\n\u2022 Access: Request a copy of your data\n\u2022 Correction: Update incorrect information\n\u2022 Deletion: Delete your account and all data\n\u2022 Portability: Export your data in standard formats\n\n7. CONTACT\nPrivacy concerns: privacy@tallydekho.com\n\nEffective date: 23 January 2025";var l=o.StyleSheet.create({safe:{flex:1,backgroundColor:r(d[7]).Colors.pageBg},header:{flexDirection:'row',alignItems:'center',paddingHorizontal:r(d[7]).Spacing.base,paddingVertical:10,backgroundColor:r(d[7]).Colors.cardBg,borderBottomWidth:1,borderBottomColor:r(d[7]).Colors.borderDefault},back:{fontSize:22,color:r(d[7]).Colors.textPrimary,marginRight:r(d[7]).Spacing.sm},title:{flex:1,fontSize:r(d[7]).Typography.md,fontWeight:r(d[7]).Typography.weightSemibold,textAlign:'center'},content:{padding:r(d[7]).Spacing.xl},date:{fontSize:r(d[7]).Typography.sm,color:r(d[7]).Colors.textTertiary,marginBottom:r(d[7]).Spacing.base,fontStyle:'italic'},body:{fontSize:r(d[7]).Typography.base,color:r(d[7]).Colors.textSecondary,lineHeight:24}})},941,[1,69,2,239,529,674,683,661]);
